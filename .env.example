# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Strava API (used by scripts/lib/strava_api.py + scripts/strava_sync.py)
# ---------------------------------------------------------------------------
# Get these at https://www.strava.com/settings/api after creating an app.
# The refresh_token is permanent; access_token is auto-rotated and cached
# at ~/.endurance-coach/strava_tokens.json.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_ATHLETE_ID=

# ---------------------------------------------------------------------------
# intervals.icu API (optional — primary location is ~/.endurance-coach/config.json)
# ---------------------------------------------------------------------------
# Only set these if you prefer .env over the config.json bootstrap path.
# INTERVALS_ATHLETE_ID=
# INTERVALS_API_KEY=
